{
  "testEnvironment": "node",
  "collectCoverage": true,
  "collectCoverageFrom": [
    "src/**/*.js",
    "!src/index.js",
    "!src/server.js"
  ],
  "coveragePathIgnorePatterns": [
    "/node_modules/"
  ],
  "testMatch": [
    "**/__tests__/**/*.js",
    "**/?(*.)+(spec|test).js"
  ],
  "moduleFileExtensions": ["js"],
  "testPathIgnorePatterns": ["/node_modules/"]
}
