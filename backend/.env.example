# Environment Configuration for NETRUNNER Multiplayer Backend

# Server
NODE_ENV=development
PORT=5000
HOST=localhost

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/netrunner?retryWrites=true&w=majority
MONGODB_LOCAL_URI=mongodb://localhost:27017/netrunner

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=7d

# OAuth - GitHub
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:5000/auth/github/callback

# OAuth - Google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# Session
SESSION_SECRET=your-session-secret-key-change-in-production

# CORS
CORS_ORIGIN=http://localhost:8000,http://localhost:3000

# Game Balance
DUEL_CURRENCY_MIN=1000
DUEL_CURRENCY_MAX=10000
GUILD_MAX_MEMBERS=50
BOT_COUNT=30

# Feature Flags
ENABLE_PVP=true
ENABLE_GUILDS=true
ENABLE_EVENTS=true
ENABLE_BOTS=true

# Logging
LOG_LEVEL=debug
LOG_FORMAT=combined
