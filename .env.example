# NETRUNNER Production Environment Configuration
# Copy this to .env and fill in your values

# ============================================================
# Frontend Configuration
# ============================================================
FRONTEND_PORT=8000
API_URL=https://api.netrunner.game
FRONTEND_HOST=0.0.0.0

# ============================================================
# Backend Configuration
# ============================================================
BACKEND_PORT=3000
NODE_ENV=production
BACKEND_HOST=0.0.0.0

# ============================================================
# Database Configuration
# ============================================================
DATABASE_URL=postgresql://netrunner:your_secure_password@localhost:5432/netrunner
DB_USER=netrunner
DB_PASSWORD=your_secure_password_here
DB_HOST=postgres
DB_PORT=5432
DB_NAME=netrunner

# ============================================================
# Security Configuration
# ============================================================
JWT_SECRET=your_very_long_random_jwt_secret_here_at_least_32_chars
CORS_ORIGIN=https://netrunner.game
SSL_KEY_PATH=/etc/ssl/private/netrunner.key
SSL_CERT_PATH=/etc/ssl/certs/netrunner.crt

# ============================================================
# Monitoring & Observability
# ============================================================
SENTRY_DSN=https://your-key@sentry.io/your-project-id
SENTRY_ENVIRONMENT=production
SENTRY_SAMPLE_RATE=1.0

# ============================================================
# Rate Limiting
# ============================================================
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================================
# Cache Configuration
# ============================================================
CACHE_TTL=300000
REDIS_URL=redis://localhost:6379

# ============================================================
# Email Configuration (for future notifications)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ============================================================
# Game Configuration
# ============================================================
MAX_PLAYERS_ONLINE=10000
MAX_GUILDS=100
PRESTIGE_RESET_ENABLED=true
TRADING_ENABLED=true

# ============================================================
# Feature Flags
# ============================================================
FEATURE_PVP=true
FEATURE_GUILDS=true
FEATURE_EVENTS=true
FEATURE_PRESTIGE=true
FEATURE_TRADING=true

# ============================================================
# Docker Configuration
# ============================================================
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=your_docker_username
DOCKER_PASSWORD=your_docker_password
